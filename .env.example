# Ejemplo de variables de entorno requeridas para Producción (Vercel) / Local (Desarrollo)

# URLs de Supabase (Obligatorias)
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR_PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Opcional: Solo si utilizas scripts de Node (como los antiguos tmp_*.js) de RLS o Admin directos
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Opcional (Dependiendo de si tu sistema requiere conexión directa a base de datos PostgreSQL)
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"
